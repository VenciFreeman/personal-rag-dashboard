# nav_dashboard module .gitignore
# Inherits from root .gitignore, this file adds module-specific rules

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual environment
.venv/
venv/

# IDE
.vscode/
.idea/

# Runtime data and artifacts
/data/
/data.backup/
*.db
*.sqlite3

# Module-specific caches
web/static/dist/
web/build/
.next/
.parcel-cache/

# Logs
*.log

# Temporary files
*.tmp
*_temp_*