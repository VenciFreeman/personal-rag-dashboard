# library_tracker module .gitignore
# Inherits from root .gitignore, this file adds module-specific rules

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual environment
.venv/
venv/

# IDE
.vscode/
.idea/

# Runtime data
/data/
/data.backup/

# Database files
*.db
*.sqlite3

# Logs and temporary
*.log
*.tmp
*_temp_*

# OS/IDE
.DS_Store
Thumbs.db