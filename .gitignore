# Workspace-level ignore rules

# Python virtual environments
.venv/
venv/
env/
**/.venv/
**/venv/

# Local model assets
local_models/
**/local_models/

# Private vector index lives in sub-repo private-data branch.
core_service/data/vector_db/**
!core_service/data/vector_db/.gitkeep

# Python cache/build artifacts
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
.eggs/
build/
dist/

# Notebook/runtime
.ipynb_checkpoints/

# Logs and temp files
*.log
*.tmp
*.temp

# Node/frontend artifacts
node_modules/
.npm/
.pnpm-store/
.yarn/
*.tsbuildinfo

# IDE/editor
.vscode/
.idea/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Local tooling and runtime state
.claude/
/core_service/data
data/benchmark_results.json
data/*.sqlite3
data/*.db
data/nav_dashboard_deploy.json
