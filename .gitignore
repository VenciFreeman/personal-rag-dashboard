################################################################################
# Root-level .gitignore for personal-ai-stack
# Last updated: 2026-04-04
#
# This is a personal project workspace, we ignore:
# - Development/runtime artifacts (venv, caches, logs)
# - All runtime data and backups (mounted under /data/)
# - IDE and OS files
# - Build and dist outputs
# - Large model caches and local models
#
# Note: /data/ paths are ALWAYS ignored at workspace level.
# If a specific app or module needs to version certain data,
# use a !-prefixed pattern in its own .gitignore.
################################################################################

# ==============================================================================
# Python virtual environments and local development
# ==============================================================================
.venv/
venv/
env/
ENV/
.python-version
.pipdeptree

# ==============================================================================
# Python runtime artifacts
# ==============================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-log.txt
pip-delete-this-directory.txt
.venv.lock

# ==============================================================================
# Testing and coverage
# ==============================================================================
.pytest_cache/
.pytest_tmp/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/
.hypothesis/

# ==============================================================================
# Jupyter / iPython
# ==============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints
*.ipynb

# ==============================================================================
# IDE and editor
# ==============================================================================
.vscode/
.code-workspace
.idea/
*.iml
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ==============================================================================
# Environment and secrets
# ==============================================================================
.env
.env.local
.env.*.local
!.env.example
env.local.ps1

# ==============================================================================
# Runtime data (ALL data is in /data/ - ALWAYS exclude)
# ==============================================================================
/data/
/data/core_service/lan_auth.sqlite3
/ai_conversations_summary/data/
/nav_dashboard/data/
/nav_dashboard/data.backup/
/library_tracker/data/
/library_tracker/data.backup/
/property/data/
/property/data.backup/
/journey/data/
/journey/data.backup/
/core_service/data/
/core_service/data.backup/
*.backup
*.backup.*

# ==============================================================================
# Large model caches and local models (use environment variables to manage)
# ==============================================================================
local_models/
**/local_models/
data/core_service/hf_cache/
data/core_service/local_models/
data/core_service/vector_db/
**/hf_cache/
**/huggingface_cache/
transformers_cache/

# ==============================================================================
# Build, distribution, packaging
# ==============================================================================
*.whl
*.tar.gz
*.zip
build/
dist/
*.egg-info/
.eggs/
# Pre-built wheels or compiled extensions (should not version)
*.so

# ==============================================================================
# Node/frontend artifacts (if any frontend exists in future)
# ==============================================================================
node_modules/
.npm/
.pnpm-store/
.yarn/
*.tsbuildinfo
dist_web/
webpack_dist/

# ==============================================================================
# Logs, temporary, and debug files
# ==============================================================================
*.log
*.log.*
*.tmp
*.temp
*.bak
.DS_Store.lock
_tmp_*/
*_tmp_*.json
*.pid

# ==============================================================================
# Backup and export tarballs (generated at runtime, can be restored from backup)
# ==============================================================================
personal_data_backup_*.zip
pre_restore_backup_*.zip
personal_data_export_*.zip
data_backup_*.tar.gz
backup_*.zip

# ==============================================================================
# macOS specific
# ==============================================================================
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.TemporaryItems
.fseventsd
.DS_Store

# ==============================================================================
# Linux/Unix specific
# ==============================================================================
.directory
.Trash-*

# ==============================================================================
# Windows specific
# ==============================================================================
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# ==============================================================================
# Project-specific temporary/runtime files
# ==============================================================================
_tmp_post_fix_smoke.json
.pytest_tmp_*
test_output_*.json
benchmark_run_*.json

data/core_service/.core_runtime_data_migrated.json
/ai_conversations_summary
/library_tracker/web/static
/nav_dashboard/favicon_logosc
/tests
/nav_dashboard/web/static
/scripts/dev
/scripts/dev
/tests
