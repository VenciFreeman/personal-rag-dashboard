# Workspace-level ignore rules

# Python virtual environments
.venv/
venv/
env/
**/.venv/
**/venv/

# Local model assets
local_models/
**/local_models/

# Private vector index lives in sub-repo private-data branch.
core_service/data/vector_db/**
!core_service/data/vector_db/.gitkeep

# Python cache/build artifacts
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
.eggs/
build/
dist/

# Notebook/runtime
.ipynb_checkpoints/

# Logs and temp files
*.log
*.tmp
*.temp

# Node/frontend artifacts
node_modules/
.npm/
.pnpm-store/
.yarn/
*.tsbuildinfo

# IDE/editor
.vscode/
.idea/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
Desktop.ini
/core_service/data
data/benchmark_results.json
env.local.ps1
.gitmodules
_tmp_run_two_rag_checks.ps1
_tmp_benchmark_rag_two_requests.ps1
/ai_conversations_summary/data/cache
/ai_conversations_summary/data/summarize_dir
/ai_conversations_summary/documents
/ai_conversations_summary/data
/ai_conversations_summary/web/static
/library_tracker/data
/nav_dashboard/web/static
/nav_dashboard/favicon_logosc
/library_tracker/web/static
/wardrobe
