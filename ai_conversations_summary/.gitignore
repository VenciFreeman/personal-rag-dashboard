# ai_conversations_summary module .gitignore
# Inherits from root .gitignore, this file adds module-specific rules

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual environment
.venv/
venv/

# IDE
.vscode/
.idea/

# Runtime data (all ignored, including RAG artifacts)
/data/
/data.backup/

# RAG-specific caches (too large to version)
data/hf_cache/
data/local_models/
data/vector_db/
data/rag_sessions/
data/raw_dir/
data/extracted_dir/
data/split_dir/
data/cache/

# Build and process artifacts
data/workflow_state.json
data/rag_rebuild.pid
scripts/summarize_failed.log

# Logs and temporary
*.log
*.tmp
*_tmp_*.json

# OS/IDE
.DS_Store
Thumbs.db