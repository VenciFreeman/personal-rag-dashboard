# -----------------------------
# Python cache / bytecode
# -----------------------------
__pycache__/
*.py[cod]
*.pyo

# -----------------------------
# Virtual environments
# -----------------------------
.venv/
venv/
env/
ENV/

# -----------------------------
# IDE / OS noise
# -----------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# -----------------------------
# Runtime data (private/generated)
# Keep folder structure, ignore contents.
# -----------------------------
data/raw_dir/**
!data/raw_dir/.gitkeep

data/extracted_dir/**
!data/extracted_dir/.gitkeep

data/summarize_dir/**
!data/summarize_dir/.gitkeep

# Local model caches / downloaded artifacts
data/hf_cache/**
!data/hf_cache/.gitkeep

data/local_models/**
!data/local_models/.gitkeep

# Local vector index artifacts
data/vector_db/**
!data/vector_db/.gitkeep

# Generated categorized notes (often personal/private)
documents/**
!documents/.gitkeep
!documents/examples/
!documents/examples/**

# -----------------------------
# Logs / temporary files
# -----------------------------
scripts/summarize_failed.log
*.log
*.tmp
*_tmp_*.json

# -----------------------------
# Packaging / build outputs
# -----------------------------
build/
dist/
release/build/
release/dist/
scripts/build/
scripts/dist/
scripts/release/
scripts/.pyi_build/
release/.pyi_build/

# PyInstaller artifacts
*.spec.bak
*.toc
*.pyz
*.pkg
release/AI-Summary-GUI.spec

# Windows binaries (keep .bat scripts)
*.exe
!*.bat

# Release app runtime data
release/app/data/raw_dir/**
!release/app/data/raw_dir/.gitkeep
release/app/data/extracted_dir/**
!release/app/data/extracted_dir/.gitkeep
release/app/data/summarize_dir/**
!release/app/data/summarize_dir/.gitkeep
release/app/data/vector_db/**
!release/app/data/vector_db/.gitkeep
release/app/documents/**
!release/app/documents/.gitkeep
!release/app/documents/examples/
!release/app/documents/examples/**
